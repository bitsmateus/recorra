# ============================================================
# Recorra — variáveis de ambiente
# Copie para .env e preencha. NUNCA commite o .env real.
# ============================================================

NODE_ENV=development
PORT=3000

# --- Banco de dados (PostgreSQL) ---
DATABASE_URL=postgresql://recorra:recorra@localhost:5432/recorra?schema=public

# --- Redis (filas BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Segurança ---
# Mínimo 32 caracteres. Gere com: openssl rand -base64 48
JWT_SECRET=troque-isto-por-um-segredo-aleatorio-de-no-minimo-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
# Chave AES-256 (32 bytes em base64) para cifrar credenciais de terceiros no banco
# Gere com: openssl rand -base64 32
ENCRYPTION_KEY=troque-isto-32-bytes-base64==

# --- App ---
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# --- WhatsApp: provider padrão do tenant pode sobrescrever ---
# cloud | evolution | uazapi
# As credenciais reais ficam por-tenant em ChannelAccount (cifradas).
# Estes são apenas defaults/fallback para desenvolvimento.
WA_CLOUD_TOKEN=
WA_CLOUD_PHONE_ID=
EVOLUTION_API_URL=
EVOLUTION_API_KEY=

# --- E-mail (verificação/convite) ---
# Sem RESEND_API_KEY, os e-mails são apenas logados (modo dev).
RESEND_API_KEY=
MAIL_FROM=Recorra <no-reply@recorra.com.br>

# --- Google SSO (opcional) ---
GOOGLE_CLIENT_ID=

# --- Observabilidade ---
SENTRY_DSN=
LOG_LEVEL=info
UAZAPI_API_URL=
UAZAPI_API_KEY=

# IA (assistente de régua e de mensagem) — OpenAI gpt-4o-mini
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
